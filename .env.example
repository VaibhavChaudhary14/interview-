# ─── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/screening_db
VECTOR_STORE_PATH=/app/data/chroma

# ── LLM Provider Keys (priority: groq > gemini > openai > template fallback)
# Leave all blank to use the built-in template question bank (no API key needed)
GROQ_API_KEY=gsk_xxxxxxxx
GEMINI_API_KEY=AQ.xxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx

# ── Model names
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# ── Embeddings (local, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ── Interview
MAX_QUESTIONS_PER_SESSION=8
SIMILARITY_THRESHOLD=0.35
RETRIEVAL_K=4
ADAPTIVE_MODE=false

# ── App
ENV=development
LOG_LEVEL=INFO

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
